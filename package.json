{
  "name": "3d-print-tfm",
  "description": "Ecommerce de impresion 3d",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint --max-warnings=0",
    "lint:fix": "next lint --fix --max-warnings=0",
    "lint:strict": "next lint --max-warnings=0 --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest --run tests/unit",
    "test:unit:coverage": "vitest --coverage --run tests/unit",
    "test:integration": "VITEST_ENV=integration vitest --run --reporter=verbose tests/integration",
    "test:integration:watch": "VITEST_ENV=integration vitest tests/integration",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:setup": "npm run test:docker:setup && npx playwright test --project=setup",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:docker:up": "docker-compose -f docker-compose.test.yml up -d && npm run test:docker:wait",
    "test:docker:down": "docker-compose -f docker-compose.test.yml down",
    "test:docker:wait": "node scripts/wait-for-postgres.mjs",
    "test:docker:setup": "npm run test:docker:up && npm run test:db:migrate && npm run test:db:seed",
    "test:db:migrate": "DATABASE_URL='postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test' npx prisma migrate deploy",
    "test:db:seed": "DATABASE_URL='postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test' tsx prisma/seed.ts",
    "test:all": "npm run test:docker:setup && npm run test:integration && npm run test:e2e && npm run test:docker:down",
    "test:validate-db": "NODE_ENV=test tsx scripts/validate-db-safety.ts",
    "detect-errors": "node scripts/detect-errors.js",
    "detect-errors:strict": "node scripts/detect-errors.js --strict",
    "check-code": "npm run detect-errors && npm run lint && npm run type-check",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:studio": "echo '⚠️  WARNING: Using current DATABASE_URL from .env. For TEST database, use: npm run db:studio:test' && prisma studio",
    "db:studio:test": "DATABASE_URL='postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test' prisma studio",
    "db:studio:prod": "echo '❌ ERROR: Never use production database with Prisma Studio. This is blocked for safety.' && exit 1",
    "db:setup:dev": "npm run db:migrate:dev && npm run db:seed:dev",
    "db:migrate:dev": "DATABASE_URL='postgresql://postgres.hkjknnymctorucyhtypm:putWa3-jinpeg-vorjeh@aws-1-eu-west-1.pooler.supabase.com:5432/postgres' npx prisma migrate deploy",
    "db:seed:dev": "DATABASE_URL='postgresql://postgres.hkjknnymctorucyhtypm:putWa3-jinpeg-vorjeh@aws-1-eu-west-1.pooler.supabase.com:5432/postgres' npx prisma db seed",
    "db:studio:dev": "DATABASE_URL='postgresql://postgres.hkjknnymctorucyhtypm:putWa3-jinpeg-vorjeh@aws-1-eu-west-1.pooler.supabase.com:5432/postgres' npx prisma studio",
    "db:migrate:prod": "DATABASE_URL='postgresql://postgres.ctwbppfkfsuxymfouptb:putWa3-jinpeg-vorjeh@aws-1-eu-central-1.pooler.supabase.com:5432/postgres' npx prisma migrate deploy",
    "db:seed:prod": "tsx scripts/seed-prod-with-confirmation.ts",
    "db:studio:prod:blocked": "echo '❌ ERROR: Prisma Studio en producción está BLOQUEADO por seguridad.' && echo 'Motivo: Evitar modificación/eliminación accidental de datos reales.' && exit 1",
    "db:reset:dev": "DATABASE_URL='postgresql://postgres.hkjknnymctorucyhtypm:putWa3-jinpeg-vorjeh@aws-1-eu-west-1.pooler.supabase.com:5432/postgres' DIRECT_URL='postgresql://postgres.hkjknnymctorucyhtypm:putWa3-jinpeg-vorjeh@db.hkjknnymctorucyhtypm.supabase.co:5432/postgres' tsx scripts/reset-and-seed.ts",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --cache",
      "prettier --check"
    ],
    "*.{js,jsx}": [
      "eslint --max-warnings=0 --cache --no-ignore",
      "prettier --check"
    ],
    "*.{json,css,scss,md,yml,yaml}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@paypal/paypal-js": "^9.5.0",
    "@paypal/react-paypal-js": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "^4.3.2",
    "@stripe/react-stripe-js": "^2.7.0",
    "@stripe/stripe-js": "^3.3.0",
    "@types/bcryptjs": "^2.4.6",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "puppeteer": "^24.40.0",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "stripe": "^15.7.0",
    "vercel": "^50.42.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.19.37",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.2",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^1.3.1"
  }
}
