{
  "name": "3d-print-tfm",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:unit": "vitest --run tests/unit",
    "test:integration": "VITEST_ENV=integration vitest --run --reporter=verbose tests/integration",
    "test:integration:watch": "VITEST_ENV=integration vitest tests/integration",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:setup": "npm run test:docker:setup && npx playwright test --project=setup",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:docker:up": "docker-compose -f docker-compose.test.yml up -d && npm run test:docker:wait",
    "test:docker:down": "docker-compose -f docker-compose.test.yml down",
    "test:docker:wait": "node scripts/wait-for-postgres.js",
    "test:docker:setup": "npm run test:docker:up && npm run test:db:migrate && npm run test:db:seed",
    "test:db:migrate": "DATABASE_URL='postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test' npx prisma migrate deploy",
    "test:db:seed": "DATABASE_URL='postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test' tsx prisma/seed.ts",
    "test:all": "npm run test:docker:setup && npm run test:integration && npm run test:e2e && npm run test:docker:down",
    "test:validate-db": "NODE_ENV=test tsx scripts/validate-db-safety.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.0.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@paypal/paypal-js": "^9.5.0",
    "@paypal/react-paypal-js": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "^4.3.2",
    "@stripe/react-stripe-js": "^2.7.0",
    "@stripe/stripe-js": "^3.3.0",
    "bcrypt": "^5.1.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "puppeteer": "^24.40.0",
    "react": "^18",
    "react-dom": "^18",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^15.7.0",
    "vercel": "^50.42.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.19.37",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^24.1.3",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^1.3.1"
  }
}
