// ============================================
// PRISMA SCHEMA - E-COMMERCE 3D PRINT TFM
// ============================================
// Stack: Next.js + PostgreSQL + Prisma
// Locale: Code in English, UI in Spanish

// ============================================
// GENERATOR & DATASOURCE
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS - 100% English
// ============================================

enum Role {
  CUSTOMER
  ADMIN
}

enum Category {
  DECORATION
  ACCESSORIES
  FUNCTIONAL
  ARTICULATED
  TOYS
}

enum Material {
  PLA
  PETG
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CARD
  BIZUM
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  CANCELLATION
  RETURN
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  ORDER_DELAYED
  PAYMENT_FAILED
  SYSTEM_ERROR
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  IGNORED
}

// ============================================
// MODEL 1: USERS
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique @db.VarChar(255)
  password      String    @db.VarChar(255)
  name          String    @db.VarChar(100) @map("nombre")
  phone         String?   @db.VarChar(20) @map("telefono")
  role          Role      @default(CUSTOMER) @map("rol")
  
  taxId         String?   @db.VarChar(20) @map("nif")
  fiscalName    String?   @db.VarChar(200) @map("nombreFiscal")
  
  isActive      Boolean   @default(true) @map("activo")
  emailVerified DateTime? @map("emailVerificado")
  lastAccess    DateTime? @map("ultimoAcceso")
  failedAttempts Int      @default(0) @map("intentosFallidos")
  lockedUntil   DateTime? @map("bloqueadoHasta")
  
  createdAt     DateTime  @default(now()) @map("creadoEn")
  updatedAt     DateTime  @updatedAt @map("actualizadoEn")
  createdBy     String?   @map("creadoPor")
  
  addresses     Address[]
  orders        Order[]
  payments      Payment[]
  messages      OrderMessage[]
  inventoryMovements InventoryMovement[]
  resolvedAlerts Alert[] @relation("ResolvedAlerts")
  sessions      Session[]
  cart          Cart?

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@map("usuarios")
}

// ============================================
// MODEL 2: ADDRESSES
// ============================================

model Address {
  id            String    @id @default(uuid())
  userId        String    @map("usuarioId")
  
  name          String    @db.VarChar(100) @map("nombre")
  recipient     String    @db.VarChar(100) @map("destinatario")
  phone         String    @db.VarChar(20) @map("telefono")
  address       String    @db.VarChar(255) @map("direccion")
  complement    String?   @db.VarChar(100) @map("complemento")
  postalCode    String    @db.VarChar(10) @map("codigoPostal")
  city          String    @db.VarChar(100) @map("ciudad")
  province      String    @db.VarChar(100) @map("provincia")
  country       String    @default("Spain") @db.VarChar(50) @map("pais")
  
  isDefault     Boolean   @default(false) @map("esPrincipal")
  
  createdAt     DateTime  @default(now()) @map("creadoEn")
  updatedAt     DateTime  @updatedAt @map("actualizadoEn")
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderShipments Order[]  @relation("ShippingAddress")
  carts         Cart[]
  
  @@index([userId])
  @@index([isDefault])
  @@map("direcciones")
}

// ============================================
// MODEL 3: PRODUCTS
// ============================================

model Product {
  id            String    @id @default(uuid())
  slug          String    @unique @db.VarChar(100)
  
  name          String    @db.VarChar(200) @map("nombre")
  description   String    @db.Text @map("descripcion")
  shortDescription String? @db.VarChar(255) @map("descripcionCorta")
  
  price         Decimal   @db.Decimal(10, 2) @map("precio")
  previousPrice Decimal?  @db.Decimal(10, 2) @map("precioAnterior")
  
  stock         Int       @default(0) @map("stock")
  minStock      Int       @default(5) @map("stockMinimo")
  
  category      Category  @map("categoria")
  material      Material  @map("material")
  dimensions    String?   @db.VarChar(50) @map("dimensiones")
  weight        Decimal?  @db.Decimal(8, 2) @map("peso")
  printTime     Int?      @map("tiempoImpresion")
  
  metaTitle     String?   @db.VarChar(200) @map("metaTitulo")
  metaDescription String? @db.VarChar(300) @map("metaDescripcion")
  
  isActive      Boolean   @default(true) @map("activo")
  isFeatured    Boolean   @default(false) @map("destacado")
  
  images        ProductImage[] @relation("ProductImages")
  
  createdAt     DateTime  @default(now()) @map("creadoEn")
  updatedAt     DateTime  @updatedAt @map("actualizadoEn")
  
  orderItems    OrderItem[]
  movements     InventoryMovement[]
  alerts        Alert[]
  cartItems     CartItem[]
  
  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
  @@index([stock])
  @@index([price])
  @@index([createdAt])
  @@map("productos")
}

// ============================================
// MODEL 4: PRODUCT IMAGES
// ============================================

model ProductImage {
  id            String    @id @default(uuid())
  productId     String    @map("productoId")
  
  url           String    @db.VarChar(500) @map("url")
  filename      String    @db.VarChar(255) @map("nombreArchivo")
  size          Int?      @map("tamano")
  mimeType      String?   @db.VarChar(50) @map("mimeType")
  
  altText       String    @db.VarChar(255) @map("textoAlt")
  isMain        Boolean   @default(false) @map("esPrincipal")
  displayOrder  Int       @default(0) @map("orden")
  
  urlSmall      String?   @db.VarChar(500) @map("urlSmall")
  urlMedium     String?   @db.VarChar(500) @map("urlMedium")
  urlLarge      String?   @db.VarChar(500) @map("urlLarge")
  
  uploadedAt    DateTime  @default(now()) @map("subidoEn")
  
  product       Product   @relation("ProductImages", fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([productId, displayOrder])
  @@index([productId])
  @@index([isMain])
  @@map("imagenes_producto")
}

// ============================================
// MODEL 5: CART
// ============================================

model Cart {
  id         String   @id @default(uuid())
  userId     String   @unique @map("usuarioId")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  items      CartItem[]

  shippingAddressId String? @map("direccionEnvioId")
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])

  subtotal   Decimal  @db.Decimal(10, 2) @default(0) @map("subtotal")

  createdAt   DateTime @default(now()) @map("creadoEn")
  updatedAt DateTime @updatedAt @map("actualizadoEn")

  @@map("carritos")
}

model CartItem {
  id         String   @id @default(uuid())
  cartId     String   @map("carritoId")
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String    @map("productoId")
  product   Product   @relation(fields: [productId], references: [id])

  quantity   Int      @default(1) @map("cantidad")
  unitPrice Decimal   @db.Decimal(10, 2) @map("precioUnitario")

  createdAt   DateTime @default(now()) @map("creadoEn")
  updatedAt DateTime @updatedAt @map("actualizadoEn")

  @@unique([cartId, productId])
  @@map("items_carrito")
}

// ============================================
// MODEL 6: ORDERS
// ============================================

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique @db.VarChar(20) @map("numeroPedido")
  userId        String        @map("usuarioId")
  
  status        OrderStatus   @default(PENDING) @map("estado")
  
  subtotal      Decimal       @db.Decimal(10, 2) @map("subtotal")
  shipping      Decimal       @db.Decimal(10, 2) @map("envio")
  discount      Decimal?      @db.Decimal(10, 2) @map("descuento")
  total         Decimal       @db.Decimal(10, 2) @map("total")
  
  shippingAddressId String?     @map("direccionEnvioId")
  shippingName      String        @db.VarChar(100) @map("nombreEnvio")
  shippingPhone     String        @db.VarChar(20) @map("telefonoEnvio")
  shippingAddress   String        @db.VarChar(255) @map("direccionEnvio")
  shippingComplement String?     @db.VarChar(100) @map("complementoEnvio")
  shippingPostalCode String      @db.VarChar(10) @map("codigoPostalEnvio")
  shippingCity      String        @db.VarChar(100) @map("ciudadEnvio")
  shippingProvince  String        @db.VarChar(100) @map("provinciaEnvio")
  shippingCountry   String        @db.VarChar(50) @map("paisEnvio")
  
  paymentMethod    PaymentMethod @default(CARD) @map("metodoPago")
  
  stripeSessionId String?   @unique @db.VarChar(255) @map("stripeSessionId")
  stripePaymentIntentId String? @db.VarChar(255) @map("stripePaymentIntentId")
  
  customerNotes  String?       @db.Text @map("notasCliente")
  internalNotes  String?       @db.Text @map("notasInternas")
  
  shippedAt     DateTime?     @map("fechaEnvio")
  trackingNumber String?   @db.VarChar(100) @map("numeroSeguimiento")
  carrier       String?       @db.VarChar(100) @map("transportista")
  deliveredAt   DateTime?     @map("fechaEntrega")
  
  createdAt       DateTime      @default(now()) @map("creadoEn")
  updatedAt DateTime      @updatedAt @map("actualizadoEn")
  confirmedAt  DateTime?      @map("confirmadoEn")
  preparingAt  DateTime?      @map("preparandoEn")
  sentAt     DateTime?         @map("enviadoEn")
  deliveredAt2   DateTime?    @map("entregadoEn")
  cancelledAt   DateTime?      @map("canceladoEn")
  cancelledBy   String?        @map("canceladoPor")
  cancelReason  String?        @db.Text @map("motivoCancelacion")
  
  user          User          @relation(fields: [userId], references: [id])
  address       Address?      @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  items         OrderItem[]
  payment       Payment?
  invoice       Invoice?
  messages      OrderMessage[]
  movements     InventoryMovement[]
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
  @@map("pedidos")
}

// ============================================
// MODEL 7: ORDER ITEMS
// ============================================

model OrderItem {
  id            String    @id @default(uuid())
  orderId       String    @map("pedidoId")
  productId     String?   @map("productoId")
  
  name          String    @db.VarChar(200) @map("nombre")
  description   String?   @db.Text @map("descripcion")
  price         Decimal   @db.Decimal(10, 2) @map("precio")
  quantity      Int       @map("cantidad")
  category      Category  @map("categoria")
  material      Material  @map("material")
  imageUrl      String?   @db.VarChar(500) @map("imagenUrl")
  
  subtotal      Decimal   @db.Decimal(10, 2) @map("subtotal")
  
  createdAt     DateTime  @default(now()) @map("creadoEn")
  
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product?  @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([productId])
  @@map("items_pedido")
}

// ============================================
// MODEL 8: PAYMENTS
// ============================================

model Payment {
  id                    String      @id @default(uuid())
  orderId               String      @unique @map("pedidoId")
  userId                String      @map("usuarioId")
  
  amount                Decimal     @db.Decimal(10, 2) @map("monto")
  refundedAmount        Decimal?    @db.Decimal(10, 2) @map("montoReembolsado")
  
  method                PaymentMethod @default(CARD) @map("metodo")
  status                PaymentStatus @default(PENDING) @map("estado")
  
  stripeSessionId       String?     @unique @db.VarChar(255) @map("stripeSessionId")
  stripePaymentIntentId String?     @unique @db.VarChar(255) @map("stripePaymentIntentId")
  stripeClientSecret    String?     @db.VarChar(255) @map("stripeClientSecret")
  stripeChargeId        String?     @db.VarChar(255) @map("stripeChargeId")
  
  errorMessage          String?     @db.Text @map("errorMensaje")
  processedAt           DateTime?   @map("fechaProcesado")
  refundedAt            DateTime?   @map("fechaReembolso")
  
  createdBy     String?   @map("creadoPor")
  createdAt     DateTime  @default(now()) @map("creadoEn")
  updatedAt DateTime  @updatedAt @map("actualizadoEn")
  
  order                 Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user                  User        @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("pagos")
}

// ============================================
// MODEL 9: INVENTORY MOVEMENTS
// ============================================

model InventoryMovement {
  id            String        @id @default(uuid())
  productId     String        @map("productoId")
  orderId       String?       @map("pedidoId")

  type          MovementType  @map("tipo")
  quantity      Int           @map("cantidad")
  previousStock Int           @map("stockAnterior")
  newStock      Int           @map("stockNuevo")

  reason        String        @db.VarChar(255) @map("motivo")
  reference     String?       @db.VarChar(100) @map("referencia")

  createdAt     DateTime      @default(now()) @map("creadoEn")
  createdBy     String        @map("creadoPor")

  product       Product       @relation(fields: [productId], references: [id])
  order         Order?        @relation(fields: [orderId], references: [id])
  user          User          @relation(fields: [createdBy], references: [id])

  @@index([productId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
  @@map("movimientos_inventario")
}

// ============================================
// MODEL 10: ALERTS
// ============================================

model Alert {
  id            String          @id @default(uuid())
  type          AlertType       @map("tipo")
  severity      AlertSeverity   @default(MEDIUM) @map("severidad")
  
  title         String          @db.VarChar(200) @map("titulo")
  message       String          @db.Text @map("mensaje")
  
  productId     String?         @map("productoId")
  orderId       String?         @map("pedidoId")
  userId        String?         @map("usuarioId")
  
  status        AlertStatus     @default(PENDING) @map("estado")
  resolvedAt    DateTime?       @map("resueltaEn")
  resolvedBy    String?         @map("resueltaPor")
  resolutionNotes String?       @db.Text @map("notasResolucion")
  
  createdAt     DateTime        @default(now()) @map("creadoEn")
  
  product       Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  resolvedByUser User?          @relation("ResolvedAlerts", fields: [resolvedBy], references: [id])
  
  @@index([type])
  @@index([status])
  @@index([severity])
  @@index([productId])
  @@index([createdAt])
  @@map("alertas")
}

// ============================================
// MODEL 11: ORDER MESSAGES
// ============================================

model OrderMessage {
  id            String    @id @default(uuid())
  orderId       String    @map("pedidoId")
  userId        String    @map("usuarioId")
  
  message       String    @db.Text @map("mensaje")
  isFromCustomer Boolean  @default(true) @map("esDeCliente")
  
  attachments   Json?     @map("adjuntos")
  
  isRead        Boolean   @default(false) @map("leido")
  readAt        DateTime? @map("leidoEn")
  
  createdAt     DateTime  @default(now()) @map("creadoEn")
  
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])
  
  @@index([orderId])
  @@index([createdAt])
  @@index([isFromCustomer])
  @@map("mensajes_pedido")
}

// ============================================
// MODEL 12: INVOICES
// ============================================

model Invoice {
  id            String    @id @default(uuid())
  orderId       String    @unique @map("pedidoId")
  
  invoiceNumber String    @unique @db.VarChar(50) @map("numeroFactura")
  series        String    @default("F") @db.VarChar(10) @map("serie")
  number        Int       @map("numero")
  
  companyName     String    @db.VarChar(200) @map("empresaNombre")
  companyTaxId    String    @db.VarChar(20) @map("empresaNif")
  companyAddress  String    @db.VarChar(255) @map("empresaDireccion")
  companyCity     String    @db.VarChar(100) @map("empresaCiudad")
  companyProvince String    @db.VarChar(100) @map("empresaProvincia")
  companyPostalCode String  @db.VarChar(10) @map("empresaCodigoPostal")
  
  clientName      String    @db.VarChar(200) @map("clienteNombre")
  clientTaxId     String    @db.VarChar(20) @map("clienteNif")
  clientAddress   String    @db.VarChar(255) @map("clienteDireccion")
  clientCity      String    @db.VarChar(100) @map("clienteCiudad")
  clientProvince  String    @db.VarChar(100) @map("clienteProvincia")
  clientPostalCode String   @db.VarChar(10) @map("clienteCodigoPostal")
  clientCountry   String    @db.VarChar(50) @map("clientePais")
  
  taxableAmount   Decimal   @db.Decimal(10, 2) @map("baseImponible")
  vatRate         Decimal   @default(21) @db.Decimal(5, 2) @map("tipoIva")
  vatAmount       Decimal   @db.Decimal(10, 2) @map("cuotaIva")
  total           Decimal   @db.Decimal(10, 2) @map("total")
  
  pdfUrl          String?   @db.VarChar(500) @map("pdfUrl")
  
  isCancelled     Boolean   @default(false) @map("anulada")
  cancelledAt     DateTime? @map("anuladaEn")
  cancelReason    String?   @db.Text @map("motivoAnulacion")
  
  issuedAt        DateTime  @default(now()) @map("emitidaEn")
  
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([invoiceNumber])
  @@index([clientTaxId])
  @@index([issuedAt])
  @@map("facturas")
}

// ============================================
// MODEL 13: SHIPPING CONFIG
// ============================================

model ShippingConfig {
  id                    String    @id @default(uuid())
  
  name                  String    @db.VarChar(100) @map("nombre")
  description           String?   @db.Text @map("descripcion")
  price                 Decimal   @db.Decimal(10, 2) @map("precio")
  
  freeShippingFrom      Decimal?  @db.Decimal(10, 2) @map("envioGratisDesde")
  
  minDays               Int       @default(3) @map("diasMinimos")
  maxDays               Int       @default(5) @map("diasMaximos")
  
  isActive              Boolean   @default(true) @map("activo")
  isDefault             Boolean   @default(false) @map("esDefecto")
  
  displayOrder          Int       @default(0) @map("orden")
  
  createdAt             DateTime  @default(now()) @map("creadoEn")
  updatedAt         DateTime  @updatedAt @map("actualizadoEn")
  
  @@index([isActive])
  @@index([isDefault])
  @@index([displayOrder])
  @@map("configuracion_envios")
}

// ============================================
// MODEL 14: SITE CONFIG
// ============================================

model SiteConfig {
  id                    String    @id @default(cuid())
  
  companyName         String    @db.VarChar(200) @map("nombreEmpresa")
  companyTaxId            String    @db.VarChar(20) @map("nifEmpresa")
  companyAddress      String    @db.VarChar(255) @map("direccionEmpresa")
  companyCity         String    @db.VarChar(100) @map("ciudadEmpresa")
  companyProvince     String    @db.VarChar(100) @map("provinciaEmpresa")
  companyPostalCode   String    @db.VarChar(10) @map("codigoPostalEmpresa")
  companyPhone        String    @db.VarChar(20) @map("telefonoEmpresa")
  companyEmail            String    @db.VarChar(255) @map("emailEmpresa")
  
  defaultVatRate      Decimal   @default(21) @db.Decimal(5, 2) @map("tipoIvaDefecto")
  
  lowStockThreshold       Int       @default(5) @map("umbralStockBajo")
  
  updatedAt         DateTime  @updatedAt @map("actualizadoEn")
  updatedBy       String?   @map("actualizadoPor")
  
  @@map("configuracion")
}

// ============================================
// MODEL 15: SESSIONS
// ============================================

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("sessionToken")
  userId       String   @map("userId")
  expires      DateTime @map("expires")
  user         User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("sesiones")
}

// ============================================
// MODEL 16: VERIFICATION TOKENS
// ============================================

model VerificationToken {
  identifier String
  token      String   @unique @map("token")
  expires    DateTime @map("expires")

  @@unique([identifier, token])
  @@map("tokens_verificacion")
}

// ============================================
// MODEL 17: AUDIT LOGS
// ============================================

model AuditLog {
  id            String    @id @default(uuid())
  
  action        String    @db.VarChar(100) @map("accion")
  entity        String    @db.VarChar(50) @map("entidad")
  entityId      String    @db.VarChar(255) @map("entidadId")
  
  previousData  Json?     @map("datosAnteriores")
  newData       Json?     @map("datosNuevos")
  
  userId        String?   @map("usuarioId")
  ipAddress     String?   @db.VarChar(45) @map("ipAddress")
  userAgent     String?   @db.Text @map("userAgent")
  
  createdAt     DateTime  @default(now()) @map("creadoEn")
  
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("logs_auditoria")
}
