# ============================================
# 3D PRINT TFM - ENVIRONMENT VARIABLES (DEVELOPMENT)
# ============================================
# Example for local development. Copy to .env.local and fill with your values.
#
# IMPORTANT: Never commit files with real credentials to git
# This example file uses DUMMY values - replace with your real keys
#
# ============================================

# ============================================
# DATABASE [REQUIRED]
# ============================================
# Example local: postgresql://postgres:postgres@localhost:5432/3dprint_tfm
# Example Supabase: postgresql://user:pass@host.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/3dprint_tfm

# ============================================
# NEXTAUTH [REQUIRED]
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here
NEXTAUTH_URL=http://localhost:3000

# ============================================
# STRIPE [REQUIRED]
# ============================================
# Get from: https://dashboard.stripe.com/test/apikeys
# Use TEST keys for development/TFM projects
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================
# PAYPAL [REQUIRED]
# ============================================
# Get from: https://developer.paypal.com/dashboard/applications
# Use SANDBOX keys for development/TFM projects
PAYPAL_CLIENT_ID=your_sandbox_client_id_here
PAYPAL_CLIENT_SECRET=your_sandbox_secret_here
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_sandbox_client_id_here

# ============================================
# GENERAL
# ============================================
NODE_ENV=development