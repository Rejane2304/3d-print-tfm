# ============================================
# 3D PRINT TFM - CONFIGURACIÓN PRODUCCIÓN
# ============================================
# ⚠️  NUNCA commitear este archivo. Solo usar como referencia.
# ============================================

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS (REQUERIDO)
# ============================================
# Usar URL de PostgreSQL proporcionada por Vercel/u otro host
DATABASE_URL="postgresql://usuario:password@host:5432/3dprint_tfm?schema=public"

# ============================================
# NEXTAUTH (REQUERIDO)
# Generar con: openssl rand -base64 32
# ============================================
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-produccion-minimo-32-caracteres"
NEXTAUTH_URL="https://tu-dominio.vercel.app"

# ============================================
# STRIPE (MODO PRODUCCIÓN - REQUERIDO)
# Obtener desde: https://dashboard.stripe.com/apikeys
# ============================================
STRIPE_SECRET_KEY="sk_live_tu_clave_secreta_produccion"
STRIPE_PUBLISHABLE_KEY="pk_live_tu_clave_publica_produccion"
STRIPE_WEBHOOK_SECRET="whsec_tu_secreto_webhook_produccion"

# ============================================
# VERCEL BLOB (OPCIONAL)
# ============================================
BLOB_READ_WRITE_TOKEN="vercel_blob_token_produccion"

# ============================================
# CONFIGURACIÓN GENERAL
# ============================================
NODE_ENV="production"
