# ============================================
# 3D PRINT TFM - ENVIRONMENT VARIABLES EXAMPLE
# ============================================
# Copiar este archivo a .env.local y rellenar con tus valores.
# NO commitar archivos .env* a git (ya están en .gitignore)
# ============================================

# ============================================
# DATABASE [REQUIRED]
# ============================================
# Para desarrollo con Supabase:
# DATABASE_URL=postgresql://user:password@host:port/database?pgbouncer=true
# DIRECT_URL=postgresql://user:password@host:port/database

# Para tests locales (Docker):
# DATABASE_URL=postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test

# ============================================
# NEXTAUTH [REQUIRED]
# ============================================
# Generar secreto: openssl rand -base64 32
NEXTAUTH_SECRET=tu-secreto-aqui
NEXTAUTH_URL=http://localhost:3000

# ============================================
# STRIPE PAYMENTS [REQUIRED]
# Obtener de: https://dashboard.stripe.com/test/apikeys
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# PAYPAL PAYMENTS [REQUIRED para PayPal]
# Obtener de: https://developer.paypal.com/dashboard/applications
# ============================================
PAYPAL_CLIENT_ID=tu-client-id-sandbox
PAYPAL_CLIENT_SECRET=tu-client-secret-sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=tu-client-id-sandbox

# ============================================
# GENERAL
# ============================================
NODE_ENV=development
CRON_SECRET=tu-cron-secret
ORDER_EXPIRATION_HOURS=24
EXPIRED_ORDERS_BATCH_SIZE=100
