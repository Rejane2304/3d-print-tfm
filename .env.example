# ============================================
# 3D PRINT TFM - ENVIRONMENT VARIABLES
# ============================================
#
# This file is used for development.
# Copy to .env and fill in your values.
# DO NOT commit .env to git (already in .gitignore)
#
# ============================================

# ============================================
# DATABASE [REQUIRED]
# ============================================
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/3dprint_tfm
DATABASE_URL=

# ============================================
# AUTHENTICATION (NextAuth) [REQUIRED]
# ============================================
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ============================================
# STRIPE PAYMENTS [REQUIRED]
# Get from: https://dashboard.stripe.com/test/apikeys
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ============================================
# PAYPAL PAYMENTS [REQUIRED for PayPal]
# Get from: https://developer.paypal.com/dashboard/applications
# ============================================
# Sandbox Mode (for testing):
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ============================================
# STORAGE (Optional)
# ============================================
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ============================================
# EMAIL SMTP (Optional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=

# ============================================
# GOOGLE OAUTH (Optional)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# GENERAL
# ============================================
NODE_ENV=development
