# ============================================
# 3D PRINT TFM - VARIABLES DE ENTORNO
# ============================================
# 
# INSTRUCCIONES:
# 1. Completa todas las variables marcadas con [REQUERIDO]
# 2. No compartas este archivo ni lo subas al repositorio
# 3. Para desarrollo local, copia este archivo a .env.local
#
# ============================================

# ============================================
# BASE DE DATOS [REQUERIDO - SUPABASE SESSION POOLER]
# ============================================
# 
# IMPORTANTE: Usar SIEMPRE "Session Pooler", NO "Direct Connection"
# 
# Pasos:
# 1. Crear cuenta en https://supabase.com
# 2. Crear proyecto "3dprint-tfm-dev"
# 3. Click en "Connect" → Seleccionar "Session pooler"
# 4. Copiar DATABASE_URL (reemplazar [YOUR-PASSWORD])
#
# Ejemplo: postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=

# ============================================
# NEXTAUTH [REQUERIDO]
# Generar secreto: openssl rand -base64 32
# ============================================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ============================================
# STRIPE [REQUERIDO]
# Obtener desde: https://dashboard.stripe.com/test/apikeys
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# CONFIGURACIÓN GENERAL
# ============================================
NODE_ENV=development
