#!/bin/sh

# ═════════════════════════════════════════════════════════════════════════════
# PRE-PUSH HOOK - TOLERANCIA CERO (Zero Technical Debt)
# ═════════════════════════════════════════════════════════════════════════════
# FAIL-FAST: Se detiene al PRIMER error encontrado
# No se ejecutan tests si el código tiene errores básicos
# ═════════════════════════════════════════════════════════════════════════════

set -e

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

FAILED=0
FAIL_MSG=""

check_failed() {
  if [ $FAILED -ne 0 ]; then
    echo ""
    echo "${RED}════════════════════════════════════════════════════════════════${NC}"
    echo "${RED}  🚫 PUSH BLOQUEADO - TOLERANCIA CERO${NC}"
    echo "${RED}  $FAIL_MSG${NC}"
    echo "${YELLOW}  Solución: $1${NC}"
    echo "${RED}════════════════════════════════════════════════════════════════${NC}"
    exit 1
  fi
}

echo ""
echo "🔒 TOLERANCIA CERO - Sistema Completo de Calidad"

# ═════════════════════════════════════════════════════════════════════════════
# CHECK 0: Quality Gate Completo (ESLint + TypeScript + Prettier + SonarQube)
# ═════════════════════════════════════════════════════════════════════════════
echo "[0/6] Quality Gate Completo..."
if ! node scripts/quality-gate.js 2>/dev/null; then
  FAILED=1
  FAIL_MSG="Quality Gate falló - revisa errores arriba"
  check_failed "npm run lint:fix && npm run format"
fi
echo "${GREEN}  ✅ Quality Gate OK${NC}"

# ═════════════════════════════════════════════════════════════════════════════
# CHECK 1: ESLint (rápido)
# ═════════════════════════════════════════════════════════════════════════════
echo "[1/6] ESLint..."
if ! npm run lint --silent 2>/dev/null; then
  FAILED=1
  FAIL_MSG="ESLint encontró errores"
  check_failed "npm run lint:fix"
fi
echo "${GREEN}  ✅ ESLint OK${NC}"

# ═════════════════════════════════════════════════════════════════════════════
# CHECK 2: TypeScript
# ═════════════════════════════════════════════════════════════════════════════
echo "[2/6] TypeScript..."
if ! npm run type-check --silent 2>/dev/null; then
  FAILED=1
  FAIL_MSG="TypeScript encontró errores de tipo"
  check_failed "Revisa los errores de tipo"
fi
echo "${GREEN}  ✅ TypeScript OK${NC}"

# ═════════════════════════════════════════════════════════════════════════════
# CHECK 3: Prettier
# ═════════════════════════════════════════════════════════════════════════════
echo "[3/6] Prettier..."
if ! npm run format:check --silent 2>/dev/null; then
  FAILED=1
  FAIL_MSG="Prettier: código sin formatear"
  check_failed "npm run format"
fi
echo "${GREEN}  ✅ Prettier OK${NC}"

# ═════════════════════════════════════════════════════════════════════════════
# CHECK 4: Tests Unitarios
# ═════════════════════════════════════════════════════════════════════════════
echo "[4/6] Tests Unitarios..."
if ! npm run test:unit -- --reporter=basic --silent 2>/dev/null; then
  FAILED=1
  FAIL_MSG="Tests unitarios FALLARON"
  check_failed "npm run test:unit"
fi
echo "${GREEN}  ✅ Tests Unitarios OK${NC}"

# ═════════════════════════════════════════════════════════════════════════════
# CHECK 5: Tests de Integración
# ═════════════════════════════════════════════════════════════════════════════
echo "[5/6] Tests de Integración..."
if ! npm run test:integration 2>/dev/null | grep -q "passed"; then
  FAILED=1
  FAIL_MSG="Tests de integración FALLARON"
  check_failed "npm run test:integration"
fi
echo "${GREEN}  ✅ Tests de Integración OK${NC}"

# ═════════════════════════════════════════════════════════════════════════════
# CHECK 6: Tests E2E
# ═════════════════════════════════════════════════════════════════════════════
echo "[6/6] Tests E2E..."
if ! npm run test:e2e 2>/dev/null | grep -q "passed"; then
  FAILED=1
  FAIL_MSG="Tests E2E FALLARON"
  check_failed "npm run test:e2e"
fi
echo "${GREEN}  ✅ Tests E2E OK${NC}"

# ═════════════════════════════════════════════════════════════════════════════
# ÉXITO
# ═════════════════════════════════════════════════════════════════════════════
echo ""
echo "${GREEN}════════════════════════════════════════════════════════════════${NC}"
echo "${GREEN}  ✅ TOLERANCIA CERO: Todo OK - Push PERMITIDO${NC}"
echo "${GREEN}════════════════════════════════════════════════════════════════${NC}"
echo ""
exit 0
