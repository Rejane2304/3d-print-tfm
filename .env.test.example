# ============================================
# 3D PRINT TFM - TEST ENVIRONMENT
# ============================================
#
# SAFETY WARNING:
# - NODE_ENV must be 'test'
# - DATABASE_URL must point to a test database
# - Database name must contain "test" (case insensitive)
#
# This prevents accidental data loss in production.
#
# ============================================

NODE_ENV=test
NEXTAUTH_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# ============================================
# TEST DATABASE [REQUIRED]
# ============================================
# Database name MUST contain "test"
# Examples: 3dprint_tfm_test, myapp_test
DATABASE_URL=postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test

# ============================================
# TEST SETTINGS
# ============================================
# Tests use automatic transaction rollback by default
TEST_PERSISTENCE=false

# ============================================
# AUTHENTICATION
# ============================================
NEXTAUTH_SECRET=test-secret-do-not-use-in-production

# ============================================
# PAYMENTS (Test mode)
# ============================================
STRIPE_SECRET_KEY=sk_test_dummy
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_test_dummy

PAYPAL_CLIENT_ID=paypal_test_dummy
PAYPAL_CLIENT_SECRET=paypal_test_dummy
NEXT_PUBLIC_PAYPAL_CLIENT_ID=paypal_test_dummy
