# ============================================
# 3D PRINT TFM - TESTING (EJEMPLO)
# ============================================
#
# Este archivo es un EJEMPLO de configuración.
# Copia este contenido a .env.test para usar tests.
#
# NOTA: El archivo .env.test NO debe ser commiteado a git
# Si ves cambios en .env.test, es probable que sea configuración local

NODE_ENV="test"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# BASE DE DATOS PARA TESTS - DOCKER LOCAL
# ============================================
# 
# Configuración automática para usar PostgreSQL en Docker
# 
# Para iniciar: npm run test:docker:setup
# Luego ejecutar: npm run test:integration

DATABASE_URL=postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test

# ============================================
# CONTROL DE TESTS
# ============================================

# SKIP_DB_TESTS: Controla si los tests usan BD
#   - false: Tests se ejecutan contra BD (NORMAL)
#   - true:  Tests se saltan (SOLO en emergencias)

SKIP_DB_TESTS=false

# ============================================
# SEGURIDAD
# ============================================

# Las validaciones se ejecutan automáticamente
# Si DATABASE_URL apunta a producción, los tests fallarán
# Esto es intencional para proteger los datos

SKIP_DB_VALIDATION=false

# ============================================
# AUTENTICACIÓN (Para tests)
# ============================================

NEXTAUTH_SECRET=test-secret-do-not-use-in-production

# ============================================
# STRIPE (Para tests)
# ============================================

STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_PUBLISHABLE_KEY=pk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_test_dummy
