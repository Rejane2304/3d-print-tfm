# ============================================
# 3D PRINT TFM - TEST ENVIRONMENT CONFIGURATION
# ============================================
#
# ⚠️  SAFETY WARNING - READ CAREFULLY ⚠️
#
# This file configures the TEST environment.
# Tests will FAIL if:
#   - NODE_ENV is not 'test'
#   - DATABASE_URL doesn't point to a test database
#   - Database name doesn't contain "test"
#
# This is INTENTIONAL to prevent accidental data loss.
#
# ============================================

NODE_ENV="test"
NEXTAUTH_URL="http://localhost:3000"
BASE_URL="http://localhost:3000"

# ============================================
# TEST DATABASE - MANDATORY CONFIGURATION
# ============================================
#
# Database name MUST contain "test" (case insensitive)
# Examples of VALID names:
#   - myapp_test
#   - 3dprint_tfm_test
#   - TEST_DATABASE
#
# Examples of INVALID names (will cause tests to fail):
#   - myapp (no "test" in name)
#   - postgres (production pattern)
#   - production_db

DATABASE_URL=postgresql://testuser:testpassword123@localhost:5433/3dprint_tfm_test

# ============================================
# TEST ISOLATION MODE
# ============================================
#
# Tests run with automatic transaction rollback by default.
# Each test is wrapped in a transaction that rolls back after completion.
# This ensures test data never persists to the database.
#
# To run tests with persistence (not recommended):
#   TEST_PERSISTENCE=true npm run test

TEST_PERSISTENCE=false

# ============================================
# AUTHENTICATION (For tests)
# ============================================

NEXTAUTH_SECRET=test-secret-do-not-use-in-production

# ============================================
# STRIPE (Test mode only)
# ============================================

STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_PUBLISHABLE_KEY=pk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_test_dummy

# ============================================
# SAFETY NOTES
# ============================================
#
# 1. Never commit .env.test with real credentials
# 2. Never point DATABASE_URL to production
# 3. Tests automatically validate database safety
# 4. Transaction rollback ensures no data pollution
#
# For questions, see tests/README.md
