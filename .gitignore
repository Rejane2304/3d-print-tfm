# ============================================
# 3D PRINT TFM - ENTERPRISE .gitignore
# ============================================

# ============================================
# DEPENDENCIES
# ============================================
/node_modules
/.pnp
.pnp.js
.pnp.cjs
.yarn/install-state.gz
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn-integrity
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# NEXT.JS
# ============================================
/.next/
/out/
/dist/
/build/
.next/cache/
next-env.d.ts

# ============================================
# TYPESCRIPT
# ============================================
*.tsbuildinfo
/src/generated/prisma

# ============================================
# TESTING
# ============================================
/coverage/
.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/
*.lcov

# ============================================
# ENVIRONMENT FILES (SENSITIVE)
# ============================================
# Todas las variables de entorno
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging

# Excepto ejemplo
!.env.example
!.env.template

# ============================================
# SECRETS Y CREDENCIALES (CRÍTICO)
# ============================================
# Claves y certificados
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx
*.jks
*.keystore

# Credenciales de servicios
secrets/
credentials/
credentials.json
service-account.json
service-account*.json
google-credentials.json
firebase-credentials.json
stripe-secret.json
*.secret*
*.token*
*.password*

# Archivos de configuración sensibles
config/local*
config/production*
config/staging*
!config/*.example

# ============================================
# DATABASE
# ============================================
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite-journal
prisma/*.db
prisma/migrations/*/migration_lock.toml
*.sql.dump
*.sql.backup

# ============================================
# STORAGE Y UPLOADS
# ============================================
/tmp/
/temp/
/uploads/
/public/uploads/
/storage/
/public/storage/
*.tmp
*.temp
*.cache
.cache/

# ============================================
# UPLOADS Y ARCHIVOS DE USUARIOS
# ============================================
/public/uploads/**/*
!/public/uploads/.gitkeep
/private/uploads/**/*
!/private/uploads/.gitkeep

# ============================================
# BLOB STORAGE
# ============================================
.vercel/blob*
*.blob

# ============================================
# LOGS
# ============================================
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ============================================
# IDES Y EDITORES
# ============================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
\.\#*

# Sublime
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# ============================================
# SISTEMA OPERATIVO
# ============================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
Icon\r

# Windows
Thumbs.db
Thumbs.db?
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.nfs*
.directory

# ============================================
# GIT
# ============================================
.git/
.gitattributes
*.orig
*.diff
*.patch
*.rej

# ============================================
# CI/CD
# ============================================
.github/workflows/*.yml
!.github/workflows/*.example.yml

# ============================================
# DOCUMENTACIÓN GENERADA
# ============================================
/docs/generated/
/docs/api/
/docs/coverage/
*.html.pdf

# ============================================
# HERRAMIENTAS DE DESARROLLO
# ============================================
.eslintcache
.stylelintcache
.prettiercache
.parcel-cache/
.cache/
webpack.cache*

# ============================================
# BACKUP Y ARCHIVOS TEMPORALES
# ============================================
*.bak
*.backup
*.old
*.orig
*.save
*.tmp
*.temp
*.swp
*~

# ============================================
# ARCHIVOS DE DEPURACIÓN
# ============================================
.debug/
debug.log
debug*

# ============================================
# ARCHIVOS DE BUILD
# ============================================
*.tgz
*.tar.gz
*.zip
*.rar
*.7z
dist/
build/
out/

# ============================================
# ARCHIVOS PRIVADOS DEL PROYECTO
# ============================================
/private
/private/data/*
!/private/data/.gitkeep
/private/public/images/products/*/
!/private/public/images/products/.gitkeep
!/private/public/images/products/*/  # Mantener estructura pero no contenido

# ============================================
# ARCHIVOS DE STRIPE
# ============================================
stripe*.json
stripe*.log
.stripe/

# ============================================
# ARCHIVOS DE VERCEL
# ============================================
.vercel
.vercelignore

# ============================================
# ARCHIVOS ESPECÍFICOS DEL PROYECTO
# ============================================
# Añadir aquí archivos específicos del proyecto si es necesario

# ============================================
# EXCEPCIONES (MANTENER EN GIT)
# ============================================
# Asegurar que estos archivos NO se ignoren
!.github/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!prisma/schema.prisma
!prisma/seed.ts
!tests/
!src/
!public/
!doc/
