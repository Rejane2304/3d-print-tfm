# ============================================
# 3D PRINT TFM - ENTERPRISE .gitignore (Optimizado)
# ============================================

# DEPENDENCIAS
/node_modules
/.pnp
.pnp.js
.pnp.cjs
.yarn/install-state.gz
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn-integrity
yarn.lock
pnpm-lock.yaml
## package-lock.json: Se recomienda versionar este archivo para asegurar la consistencia de dependencias en npm
# package-lock.json

# NEXT.JS
/.next/
/out/
/dist/
/build/
.next/cache/
next-env.d.ts

# TYPESCRIPT
*.tsbuildinfo
/src/generated/prisma

# TESTING
/coverage/
.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/
*.lcov
/tests/e2e/.auth/

# ENVIRONMENT FILES (SENSITIVE)
# Todas las variables de entorno
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging

# Additional env files
.env.test
.env.production

# Excepto archivos de ejemplo (asegúrate de que no contengan datos reales)
!.env.example
!.env.template

# SECRETS Y CREDENCIALES (CRÍTICO)
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx
*.jks
*.keystore
secrets/
credentials/
credentials.json
service-account.json
service-account*.json
google-credentials.json
firebase-credentials.json
stripe-secret.json
*.secret*
*.token*
*.password*
config/local*
config/production*
config/staging*
!config/*.example

# DATABASE
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite-journal
prisma/*.db
prisma/migrations/*/migration_lock.toml
*.sql.dump
*.sql.backup

# STORAGE Y UPLOADS
/tmp/
/temp/
/uploads/
/public/uploads/
/storage/
/public/storage/
*.tmp
*.temp
.cache/

# UPLOADS Y ARCHIVOS DE USUARIOS
/public/uploads/**/*
!/public/uploads/.gitkeep
/private/uploads/**/*
!/private/uploads/.gitkeep

# BLOB STORAGE
.vercel/blob*
*.blob

# TEMPORARY FILES (Unificado)
*.tmp
*.temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
.backups/
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
Icon\r
Thumbs.db
Thumbs.db?
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk
*~
.nfs*
.directory
*.bak
*.backup
*.old
*.orig
*.save
*.swp

# GIT
.git/
.gitattributes
*.orig
*.diff
*.patch
*.rej

# CI/CD
.github/workflows/*.yml
!.github/workflows/*.example.yml

# DOCUMENTACIÓN GENERADA
/docs/generated/
/docs/api/
/docs/coverage/
*.html.pdf

# HERRAMIENTAS DE DESARROLLO
.eslintcache
.stylelintcache
.prettiercache
.parcel-cache/
.cache/
webpack.cache*

# ARCHIVOS DE DEPURACIÓN
.debug/
debug.log
debug*

# ARCHIVOS DE BUILD
*.tgz
*.tar.gz
*.zip
*.rar
*.7z
dist/
build/
out/

# ARCHIVOS PRIVADOS DEL PROYECTO
# Mantener estructura de carpetas privadas pero no versionar contenido real
/private
/private/data/*
!/private/data/.gitkeep
/private/public/images/products/*/
!/private/public/images/products/.gitkeep
!/private/public/images/products/*/  # Mantener estructura pero no contenido

# ARCHIVOS DE STRIPE
stripe*.json
stripe*.log
.stripe/

# ARCHIVOS DE VERCEL
.vercel
.vercelignore

# ARCHIVOS ESPECÍFICOS DEL PROYECTO
# Añadir aquí archivos específicos del proyecto si es necesario

# EXCEPCIONES (MANTENER EN GIT)
# Asegurar que estos archivos NO se ignoren
!.github/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!prisma/schema.prisma
!prisma/seed.ts
!tests/
!src/
!public/
!docs/
# Security - Credentials
.env.protection
